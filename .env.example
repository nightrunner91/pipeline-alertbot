# Required: Telegram Bot Token from @BotFather
TELEGRAM_BOT_TOKEN=

# =============================================================================
# MULTI-REPOSITORY MODE
# JSON array mapping GitLab projects to Telegram chats.
# Must be a single line in your actual .env file.
#
# Fields:
#   projectId    - GitLab project ID (Settings > General > Project ID)
#   projectName  - Custom display name for alerts (optional)
#   chatId       - Telegram chat/group ID to send alerts to
#   secret       - Webhook secret token (must match GitLab webhook settings)
#   style        - Alert style: "card", "tree", or "minimal" (optional)
# =============================================================================
REPOSITORY_CONFIG=[{"projectId":123,"projectName":"My Project","chatId":"-1001234567890","secret":"your-secret-here","style":"card"}]

# Global fallback style (used when a repo entry doesn't specify one)
ALERT_STYLE=card

# Port for the webhook server (optional, default: 3000)
PORT=3000

# Webhook mode: "both" (default), "jobs" (job events only), or "pipeline" (pipeline events only)
WEBHOOK_MODE=both
